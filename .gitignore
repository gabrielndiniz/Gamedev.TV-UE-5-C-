# Visual Studio 2015 user specific files
ObstacleAssault/.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
ObstacleAssault/SourceArt/**/*.png
ObstacleAssault/SourceArt/**/*.tga

# Binary Files
ObstacleAssault/Binaries/*
ObstacleAssault/Plugins/*/Binaries/*

# Builds
ObstacleAssault/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!ObstacleAssault/Build/*/
ObstacleAssault/Build/*/**
!ObstacleAssault/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!ObstacleAssault/Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
ObstacleAssault/Saved/*

# Compiled source files for the engine to use
ObstacleAssault/Intermediate/*
ObstacleAssault/Plugins/*/Intermediate/*

# Cache files for the editor to use
ObstacleAssault/DerivedDataCache/*


# Initial Map
ObstacleAssault/Content/Cursor/*
ObstacleAssault/Content/__ExternalActors__/*
ObstacleAssault/Content/__ExternalObjects__/*
ObstacleAssault/Content/Characters/Mannequins/*
ObstacleAssault/Content/Characters/Mannequin_UE4/*
ObstacleAssault/Content/MDL/*
ObstacleAssault/Content/Developers/*
ObstacleAssault/Content/LevelPrototyping/*

